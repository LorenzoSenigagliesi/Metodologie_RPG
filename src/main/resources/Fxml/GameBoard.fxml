<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="it.unicam.cs.mpgc.RPG122755.Main"
            prefHeight="720.0" prefWidth="1080.0"
            style="-fx-background-color: #1e2a38;">

    <top>
        <VBox spacing="10.0" alignment="CENTER" style="-fx-background-color: #14202c;">
            <padding>
                <Insets top="15.0" right="25.0" bottom="15.0" left="25.0"/>
            </padding>

            <Label text="Direttore d'Ospedale" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="22.0"/>
                </font>
            </Label>

            <HBox spacing="30.0" alignment="CENTER">

                <VBox spacing="4.0" alignment="CENTER">
                    <Label text="Fiducia dei Pazienti" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="13.0"/>
                        </font>
                    </Label>
                    <ProgressBar fx:id="barFiduciaPazienti" progress="0.5" prefWidth="180.0"
                                 style="-fx-accent: #4FC3F7;"/>
                    <Label fx:id="lblFiduciaPazienti" text="50 / 100" textFill="WHITE"/>
                </VBox>

                <VBox spacing="4.0" alignment="CENTER">
                    <Label text="Budget Operativo" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="13.0"/>
                        </font>
                    </Label>
                    <ProgressBar fx:id="barBudgetOperativo" progress="0.5" prefWidth="180.0"
                                 style="-fx-accent: #FFD54F;"/>
                    <Label fx:id="lblBudgetOperativo" text="50 / 100" textFill="WHITE"/>
                </VBox>

                <VBox spacing="4.0" alignment="CENTER">
                    <Label text="Morale del Personale" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="13.0"/>
                        </font>
                    </Label>
                    <ProgressBar fx:id="barMoralePersonale" progress="0.5" prefWidth="180.0"
                                 style="-fx-accent: #81C784;"/>
                    <Label fx:id="lblMoralePersonale" text="50 / 100" textFill="WHITE"/>
                </VBox>

                <VBox spacing="4.0" alignment="CENTER">
                    <Label text="Qualità delle Cure" textFill="WHITE">
                        <font>
                            <Font name="System Bold" size="13.0"/>
                        </font>
                    </Label>
                    <ProgressBar fx:id="barQualitaCure" progress="0.5" prefWidth="180.0"
                                 style="-fx-accent: #E57373;"/>
                    <Label fx:id="lblQualitaCure" text="50 / 100" textFill="WHITE"/>
                </VBox>

            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="25.0" alignment="CENTER">
            <padding>
                <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
            </padding>

            <StackPane prefHeight="110.0" maxWidth="900.0"
                       style="-fx-background-color: #2c3e50; -fx-background-radius: 12;">
                <padding>
                    <Insets top="15.0" right="25.0" bottom="15.0" left="25.0"/>
                </padding>
                <Label fx:id="lblEvento"
                       text="Un evento accade in ospedale..."
                       textFill="WHITE"
                       wrapText="true"
                       alignment="CENTER"
                       textAlignment="CENTER">
                    <font>
                        <Font name="System Italic" size="18.0"/>
                    </font>
                </Label>
            </StackPane>

            <HBox spacing="60.0" alignment="CENTER" VBox.vgrow="ALWAYS">

                <VBox fx:id="cartaSinistra"
                      spacing="15.0"
                      alignment="CENTER"
                      prefWidth="320.0"
                      prefHeight="360.0"
                      style="-fx-background-color: #ecf0f1; -fx-background-radius: 16; -fx-border-color: #bdc3c7; -fx-border-radius: 16; -fx-border-width: 2;">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                    </padding>

                    <Label text="Scelta A" textFill="#2c3e50">
                        <font>
                            <Font name="System Bold" size="20.0"/>
                        </font>
                    </Label>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Label fx:id="lblTestoSinistra"
                           text="Descrizione della scelta a sinistra..."
                           textFill="#34495e"
                           wrapText="true"
                           alignment="CENTER"
                           textAlignment="CENTER">
                        <font>
                            <Font size="15.0"/>
                        </font>
                    </Label>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Label fx:id="lblEffettiSinistra"
                           text=""
                           textFill="#7f8c8d"
                           wrapText="true"
                           alignment="CENTER"
                           textAlignment="CENTER">
                        <font>
                            <Font name="System Italic" size="12.0"/>
                        </font>
                    </Label>
                </VBox>

                <VBox fx:id="cartaDestra"
                      spacing="15.0"
                      alignment="CENTER"
                      prefWidth="320.0"
                      prefHeight="360.0"
                      style="-fx-background-color: #ecf0f1; -fx-background-radius: 16; -fx-border-color: #bdc3c7; -fx-border-radius: 16; -fx-border-width: 2;">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
                    </padding>

                    <Label text="Scelta B" textFill="#2c3e50">
                        <font>
                            <Font name="System Bold" size="20.0"/>
                        </font>
                    </Label>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Label fx:id="lblTestoDestra"
                           text="Descrizione della scelta a destra..."
                           textFill="#34495e"
                           wrapText="true"
                           alignment="CENTER"
                           textAlignment="CENTER">
                        <font>
                            <Font size="15.0"/>
                        </font>
                    </Label>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Label fx:id="lblEffettiDestra"
                           text=""
                           textFill="#7f8c8d"
                           wrapText="true"
                           alignment="CENTER"
                           textAlignment="CENTER">
                        <font>
                            <Font name="System Italic" size="12.0"/>
                        </font>
                    </Label>
                </VBox>

            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #14202c;">
            <padding>
                <Insets top="10.0" right="20.0" bottom="10.0" left="20.0"/>
            </padding>
            <Label text="Clicca una carta per fare la tua scelta" textFill="#bdc3c7">
                <font>
                    <Font name="System Italic" size="12.0"/>
                </font>
            </Label>
        </HBox>
    </bottom>

</BorderPane>
