<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="CONTROLLER_NAME"
           prefHeight="720.0" prefWidth="1080.0"
           style="-fx-background-color: #0f1419;">

    <VBox spacing="25.0" alignment="CENTER" maxWidth="700.0">
        <padding>
            <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
        </padding>

        <Label text="GAME OVER" textFill="#e74c3c">
            <font>
                <Font name="System Bold" size="64.0"/>
            </font>
        </Label>

        <Label fx:id="lblCausaSconfitta"
               text="La tua gestione dell'ospedale è terminata."
               textFill="WHITE"
               wrapText="true"
               alignment="CENTER"
               textAlignment="CENTER">
            <font>
                <Font name="System Italic" size="20.0"/>
            </font>
        </Label>

        <Region prefHeight="20.0"/>

        <VBox spacing="12.0" alignment="CENTER"
              style="-fx-background-color: #1e2a38; -fx-background-radius: 12;">
            <padding>
                <Insets top="25.0" right="35.0" bottom="25.0" left="35.0"/>
            </padding>

            <Label text="Riepilogo della partita" textFill="#bdc3c7">
                <font>
                    <Font name="System Bold" size="16.0"/>
                </font>
            </Label>

            <HBox spacing="40.0" alignment="CENTER">
                <Label text="Giorni in carica:" textFill="#bdc3c7">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </Label>
                <Label fx:id="lblGiorni" text="0" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>
                </Label>
            </HBox>

            <HBox spacing="40.0" alignment="CENTER">
                <Label text="Decisioni prese:" textFill="#bdc3c7">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </Label>
                <Label fx:id="lblDecisioni" text="0" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>
                </Label>
            </HBox>

            <HBox spacing="40.0" alignment="CENTER">
                <Label text="Fiducia dei Pazienti:" textFill="#bdc3c7">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </Label>
                <Label fx:id="lblStatFiduciaPazienti" text="0" textFill="#4FC3F7">
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>
                </Label>
            </HBox>

            <HBox spacing="40.0" alignment="CENTER">
                <Label text="Budget Operativo:" textFill="#bdc3c7">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </Label>
                <Label fx:id="lblStatBudgetOperativo" text="0" textFill="#FFD54F">
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>
                </Label>
            </HBox>

            <HBox spacing="40.0" alignment="CENTER">
                <Label text="Morale del Personale:" textFill="#bdc3c7">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </Label>
                <Label fx:id="lblStatMoralePersonale" text="0" textFill="#81C784">
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>
                </Label>
            </HBox>

            <HBox spacing="40.0" alignment="CENTER">
                <Label text="Qualità delle Cure:" textFill="#bdc3c7">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </Label>
                <Label fx:id="lblStatQualitaCure" text="0" textFill="#E57373">
                    <font>
                        <Font name="System Bold" size="14.0"/>
                    </font>
                </Label>
            </HBox>
        </VBox>

        <Region prefHeight="20.0"/>

        <HBox spacing="20.0" alignment="CENTER">

            <Button fx:id="btnRicomincia"
                    text="Ricomincia"
                    prefWidth="180.0"
                    prefHeight="45.0"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 8;">
                <font>
                    <Font name="System Bold" size="15.0"/>
                </font>
            </Button>

            <Button fx:id="btnMenu"
                    text="Menu Principale"
                    prefWidth="180.0"
                    prefHeight="45.0"
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-background-radius: 8;">
                <font>
                    <Font name="System Bold" size="15.0"/>
                </font>
            </Button>

            <Button fx:id="btnEsci"
                    text="Esci"
                    prefWidth="180.0"
                    prefHeight="45.0"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-background-radius: 8;">
                <font>
                    <Font name="System Bold" size="15.0"/>
                </font>
            </Button>

        </HBox>

    </VBox>

</StackPane>
